  "values": {
    "theme_colors": [
      { "name": "Primary",       "color": "#185FA5" },
      { "name": "Primary Light", "color": "#4A8BCC" },
      { "name": "Primary Soft",  "color": "#F0F6FC" },
      { "name": "Indigo",        "color": "#3F51B5" },
      { "name": "Accent",        "color": "#EF9F27" },
      { "name": "Amber",         "color": "#EF9F27" },
      { "name": "Green",         "color": "#1FBA8E" },
      { "name": "Teal",          "color": "#15A179" },
      { "name": "Success Soft",  "color": "#E1F5EE" },
      { "name": "Success Text",  "color": "#0F6E56" },
      { "name": "Red",           "color": "#DC3545" },
      { "name": "Danger Text",   "color": "#A32D2D" },
      { "name": "Ink",           "color": "#0A0A0F" },
      { "name": "Text",          "color": "#14141A" },
      { "name": "Muted",         "color": "#5A5A65" },
      { "name": "Light",         "color": "#8E8E97" },
      { "name": "Light Gray",    "color": "#B8B8BE" },
      { "name": "Surface",       "color": "#FAFAF7" },
      { "name": "White",         "color": "#FFFFFF" },
      { "name": "Dark",          "color": "#0F0F1A" }
    ],
    "font_sizes": [
      { "name": "Hero",     "size": "60", "class": "font-hero" },
      { "name": "Heading",  "size": "40", "class": "font-heading" },
      { "name": "Title",    "size": "22", "class": "font-title" },
      { "name": "Lead",     "size": "18", "class": "font-lead" },
      { "name": "Body",     "size": "17", "class": "font-body" },
      { "name": "Small",    "size": "15", "class": "font-small" },
      { "name": "Caption",  "size": "14", "class": "font-caption" },
