          "hover":   { "bg_color": {"predefined":"dark","custom":""}, "border_color": {"predefined":"dark","custom":""} },
          "active": {}, "focus": {}, "disabled": {}
        }
      },
      {
        "id": "0000000041", "color_name": "CTA",
        "_intent": "the `.match-cta` — green gradient, white text, no border; hover reverses stops",
        "states": {
          "default": {
            "text_color": {"predefined":"white","custom":""}, "bg_color": {"predefined":"","custom":""}, "border_color": {"predefined":"","custom":""}, "border_style": "none",
