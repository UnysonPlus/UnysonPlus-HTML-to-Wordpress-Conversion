      { "name": "Tiny",     "size": "12", "class": "font-tiny" },
      { "name": "Overline", "size": "11", "class": "font-overline" }
    ],
    "button_colors": [
      {
        "id": "0000000002", "color_name": "Primary",
        "states": {
          "default": { "text_color": {"predefined":"white","custom":""}, "bg_color": {"predefined":"primary","custom":""}, "border_color": {"predefined":"primary","custom":""} },
          "hover":   { "bg_color": {"predefined":"indigo","custom":""}, "border_color": {"predefined":"indigo","custom":""} },
          "active": {}, "focus": {}, "disabled": {}
        }
      },
      {
        "id": "0000000003", "color_name": "Success",
        "states": {
          "default": { "text_color": {"predefined":"white","custom":""}, "bg_color": {"predefined":"green","custom":""}, "border_color": {"predefined":"green","custom":""} },
          "hover":   { "bg_color": {"predefined":"teal","custom":""}, "border_color": {"predefined":"teal","custom":""} },
          "active": {}, "focus": {}, "disabled": {}
        }
      },
      {
        "id": "0000000040", "color_name": "Dark",
